{
  "manifest_version": 3,
  "name": "Full Snap — Full-Page Screenshot & Annotate",
  "short_name": "Full Snap",
  "version": "1.0.0",
  "description": "Capture entire web pages, annotate with pen & highlighter, download PNG. Full-page screenshots without the fluff.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Full Snap",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"]
}
