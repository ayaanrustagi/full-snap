{
  "manifest_version": 3,
  "name": "Full Snap — Capture, Redact & Ship",
  "short_name": "Full Snap",
  "version": "2.0.1",
  "description": "Capture a page, auto-redact emails and secrets, mark steps, then copy a report pack for Slack or Linear. 100% local — nothing uploads.",
  "homepage_url": "https://ayaanrustagi.github.io/full-snap/",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Full Snap",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "commands": {
    "capture-report": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Capture visible area with redaction"
    },
    "capture-element": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Alt+Shift+E"
      },
      "description": "Capture a page element"
    },
    "capture-region": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "Alt+Shift+R"
      },
      "description": "Capture a dragged region"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["content/editor.html", "content/editor.css", "content/editor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
